# Test binaries and artifacts
test/e2e-test
test/*.exe
test/*.test
*.test

# Allow e2e_main.go to be tracked
!test/e2e_main.go

# Environment files (credentials)
.env
.env.local
.env.*.local
*.env

# Test data files
test/*.json
test/*.csv
test/*.ndjson
test/*.gz

# Temporary files
*.tmp
*.temp
tmp/
temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.exe
*.dll
*.so
*.dylib
bin/
dist/

# Go build cache
go.work
go.work.sum

# Coverage and profiling
*.out
*.prof
coverage.txt
coverage.html

# Credentials and secrets (extra safety). Scoped to actual secret-bearing
# file shapes (env/json/yaml/dotfiles), NOT to Go source packages — the
# unscoped `*credentials*` this replaced also matched the legitimate
# `credentials/` STS provider package directory (github.com/helix-tools/
# sdk-go/v2/credentials, STS-PLAN.md §P3), which is source code containing
# no real secrets, and made it impossible to ever commit a package with
# that name.
*credentials*.json
*credentials*.yaml
*credentials*.yml
*credentials*.env
.credentials
*secrets*
*keys.json
*key.json